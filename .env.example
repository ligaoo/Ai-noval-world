# LLM 配置
# 复制此文件为 .env 并填入你的配置

# API Key（必填）
OPENAI_API_KEY=your_api_key_here

# API Base URL（默认为 OpenAI 官方，兼容其他兼容接口也可以
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型名称
OPENAI_MODEL=gpt-4o-mini

# 运行默认配置
# 默认运行模式：scripted / heuristic / llm
DEFAULT_MODE=scripted

# 默认运行 tick 数
DEFAULT_TICKS=15

# 温度参数（仅 llm 模式）
DEFAULT_TEMPERATURE=0.2
