  "truth_chain": {
    "truth_id": "VT-1001",
    "final_truth": "荒废别墅是多个平行时空的交汇点，因数百年前一次失败的空间仪式导致现实重叠。阁楼钥匙作为稳定锚点，需要集合四个来自不同现实的记忆碎片才能启动返回。缺席者曾是仪式主导者，被困在时空夹缝，暗中操纵杀人规律（各现实法则冲突随机显现），诱使受困者收集碎片以便自己逃脱。规律变化本质是不同时空法则的随机激发，触发即死意味着个体被撕裂到其他现实。",
    "reveal_steps": [
      {
        "stage": "surface",
        "chapter_range": [
          1,
          3
        ],
        "allowed_information": [
          "四人醒来发现自己躺在荒废别墅一楼大厅，门窗被神秘力量封锁",
          "通往阁楼的楼梯被无形屏障阻挡，隐约能看到钥匙悬挂在阁楼中央",
          "别墅内随机出现杀人规律（如：不能直视某个镜子、不能说出数字4、不能踩到地砖缝隙），触发即可致死",
          "规律每隔一段时间随机变换，无固定模式",
          "别墅内有干涸的血迹、破损家具、以及前人的日记残页（暗示有‘缺席者’存在但未显露）"
        ],
        "forbidden_information": [
          "不准揭示规律变化的根本原因",
          "不准提及空间重叠或平行现实",
          "不准透露缺席者的身份或目的",
          "不准说明钥匙的具体使用方法"
        ]
      },
      {
        "stage": "partial",
        "chapter_range": [
          4,
          7
        ],
        "allowed_information": [
          "从日记和壁画中拼凑出别墅过去曾进行过某种仪式，参与者包括‘缺席者’在内的五人",
          "发现规律变化与四人的潜意识活动有关：每当有人恐惧某样东西，规律就可能向该方向转变",
          "找到部分碎片：每人都有一个随身物品（如手表、项链等）刻有特殊符号，相互呼应",
          "阁楼的屏障在规律变化时偶尔减弱，但不足以取钥匙",
          "缺席者开始通过环境低语、幻觉等方式间接影响众人"
        ],
        "forbidden_information": [
          "不准揭示仪式失败导致时空重叠",
          "不准说明碎片是来自不同现实",
          "不准指明缺席者被困在夹缝中"
        ]
      },
      {
        "stage": "major",
        "chapter_range": [
          8,
          11
        ],
        "allowed_information": [
          "四人的随身物品其实是‘现实碎片’，每个碎片对应一个不同的平行世界，只有集齐才能定位返回现实",
          "规律变化是不同世界法则随机覆盖别墅区域的结果，每次变化对应一个碎片的世界",
          "缺席者实际上是第五个碎片持有者，但因仪式失败肉身消散，意识附着在别墅中，通过影响现有四人的记忆和恐惧来引导规律变化，迫使他们收集碎片并试图夺取身体",
          "阁楼钥匙是一个稳定器，需要四个碎片同时插入钥匙孔才能使用，但使用后会打开一个缺口，可能让缺席者逃脱"
        ],
